{
    "name": "roarunner/sdk",
    "type": "metapackage",
    "description": "RoadRunner SDK for PHP",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Aleksei Gagarin",
            "email": "roxblnfk@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "buggregator/trap": "^1.10",
        "infection/infection": "^0.32",
        "testo/testo": "0.1 - 1",
        "testo/bridge-infection": "0.1 - 1",
        "spiral/code-style": "^2.3",
        "vimeo/psalm": "^7"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "RoadRunner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RoadRunner\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "scripts": {
        "cs:diff": "php-cs-fixer fix --dry-run -v --diff",
        "cs:fix": "php-cs-fixer fix -v",
        "psalm": "psalm",
        "psalm:baseline": "psalm --set-baseline=psalm-baseline.xml",
        "psalm:ci": "psalm --output-format=github --shepherd --show-info=false --stats --threads=4",
        "test": [
            "@putenv XDEBUG_MODE=coverage",
            "testo --color=always"
        ],
        "test:ci": [
            "@putenv TESTO_CI=1",
            "@putenv XDEBUG_MODE=coverage",
            "testo --color=always"
        ]
    }
}
